<plugin>

<!-- Extensions -->
   <extension
         id="org.eclipse.tools.layout.spy.fragment"
         point="org.eclipse.e4.workbench.model">
      <fragment
            apply="always"
            uri="fragment.e4xmi">
      </fragment>
      <processor
            beforefragment="false"
            class="org.eclipse.tools.layout.spy.internal.processors.LayoutSpyBindingProcessor">
      </processor>
   </extension>
   <extension
         point="org.eclipse.pde.spy.core.spyPart">
      <spyPart
            description="%spy-layout-command.description"
            icon="$nl$/icons/obj16/layoutspy_obj.svg"
            name="%spy-layout-command.name"
            part="org.eclipse.tools.layout.spy.internal.parts.LayoutSpyPart">
      </spyPart>
   </extension>

</plugin>
